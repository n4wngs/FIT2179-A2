    {
      "data": {
        "values": [
          {"country": "Madagascar", "invertebrates": 358, "plants": 3038, "vertebrates": 575},
          {"country": "Brazil", "invertebrates": 112, "plants": 1519, "vertebrates": 980},
          {"country": "Australia", "invertebrates": 630, "plants": 818, "vertebrates": 489},
          {"country": "Tuvalu", "invertebrates": 163, "plants": 0, "vertebrates": 29},
          {"country": "Mauritania", "invertebrates": 6, "plants": 1, "vertebrates": 132},
          {"country": "Gabon", "invertebrates": 4, "plants": 500, "vertebrates": 137},
          {"country": "Thailand", "invertebrates": 235, "plants": 323, "vertebrates": 347},
          {"country": "Somalia", "invertebrates": 139, "plants": 104, "vertebrates": 111}
        ]
      },
      "transform": [
        {
          "calculate": "datum['invertebrates'] + datum['plants'] + datum['vertebrates']",
          "as": "TotalLevel"
        },
        {"calculate": "datum['invertebrates']/datum.TotalLevel", "as": "invertebrates_percent"},
        {
          "calculate": "datum['plants']/datum.TotalLevel",
          "as": "plants_percent"
        },
        {"calculate": "datum['vertebrates']/datum.TotalLevel", "as": "vertebrates_percent"},
        {
          "calculate": "0.5 * (2 * datum.vertebrates_percent + datum.plants_percent)",
          "as": "x"
        },
        {"calculate": "0.866 * datum.plants_percent", "as": "y"},
        {
          "calculate": "toString(isValid(datum['invertebrates']) ? datum['invertebrates'] : 0) + ' (' + toString(round((isValid(datum.invertebrates_percent) ? datum.invertebrates_percent : 0) * 100, 1)) + '%)'",
          "as": "tooltip_invertebrates"
        },
        {
          "calculate": "toString(isValid(datum['plants']) ? datum['plants'] : 0) + ' (' + toString(round((isValid(datum.plants_percent) ? datum.plants_percent : 0) * 100, 1)) + '%)'",
          "as": "tooltip_plants"
        },
        {
          "calculate": "toString(isValid(datum['vertebrates']) ? datum['vertebrates'] : 0) + ' (' + toString(round((isValid(datum.vertebrates_percent) ? datum.vertebrates_percent : 0) * 100, 1)) + '%)'",
          "as": "tooltip_vertebrates"
        },
        {"filter": "datum['country'] !== null"},
        {"calculate": "length(datum['country'])", "as": "leng"},
        {
          "calculate": "(datum.x*100 - length(datum['country']))/100",
          "as": "Xleng"
        },
        {
          "calculate": "(datum.x*100 + length(datum['country']))/100",
          "as": "Xleng2"
        },
        {
          "calculate": "datum['invertebrates_percent'] > 0.8 ? '#FF0F0F' : datum['plants_percent'] > 0.8 ? '#FFC333' : datum['vertebrates_percent'] > 0.8 ? '#32F95D' : datum['invertebrates_percent'] > 0.5 && datum['plants_percent'] > datum['vertebrates_percent'] ? '#ff3c18' : datum['invertebrates_percent'] > 0.5 && datum['plants_percent'] < datum['vertebrates_percent'] ? '#cb4922' : datum['plants_percent'] > 0.5 && datum['invertebrates_percent'] > datum['vertebrates_percent'] ? '#ff962a' : datum['plants_percent'] > 0.5 && datum['invertebrates_percent'] < datum['vertebrates_percent'] ? '#cbd03d' : datum['vertebrates_percent'] > 0.5 && datum['plants_percent'] < datum['invertebrates_percent'] ? '#65be49' : datum['vertebrates_percent'] > 0.5 && datum['plants_percent'] > datum['invertebrates_percent'] ? '#65eb52' : '#43c1ce'",
          "as": "color"
        },
        {"calculate": "datum.plants_percent > 0.9 ? 15 : -15", "as": "dy_val"}
      ],
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "quantitative"},
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "country:"},
          {"field": "tooltip_invertebrates", "type": "nominal", "title": "🔴 invertebrates:"},
          {"field": "tooltip_plants", "type": "nominal", "title": "🟡 plants:"},
          {"field": "tooltip_vertebrates", "type": "nominal", "title": "🟢 vertebrates:"}
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "point",
            "stroke": "#000000",
            "strokeWidth": 1.5
          },
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "fill": {"field": "color", "type": "nominal", "scale": null},
            "size": {
              "field": "TotalLevel",
              "type": "quantitative",
              "legend": null,
              "scale": {"range": [50, 500]}
            }
          }
        },
        {
          "mark": {
            "type": "text",
            "font": "Verdana",
            "dy": {"expr": "datum.dy_val"},
            "fontSize": 13,
            "color": "#000000",
            "fontWeight": 100
          },
          "encoding": {
            "x": {"field": "x", "type": "quantitative"},
            "y": {"field": "y", "type": "quantitative"},
            "text": {"field": "country", "type": "nominal"}
          }
        }
      ]
    }
