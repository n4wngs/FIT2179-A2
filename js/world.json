{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Threatened Species by Country Over Time",
  "width": 800,
  "height": 400,
  "projection": {
    "type": "equalEarth"
  },
  "params": [
    {
      "name": "Year_Selection",
      "value": 2024,
      "bind": {
        "input": "select",
        "options": [2004, 2010, 2015, 2020, 2024],
        "name": "Select Year: "
      }
    },
    {
      "name": "Category_Selection",
      "value": "total_threatened",
      "bind": {
        "input": "select",
        "options": [
          "total_threatened",
          "plants",
          "vertebrates",
          "invertebrates"
        ],
        "labels": [
          "Total Threatened",
          "Plants",
          "Vertebrates",
          "Invertebrates"
        ],
        "name": "Select Category: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/vega-datasets@v1.29.0/data/world-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e0e0e0",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "datum": "No Data",
          "scale": {"range": ["#e0e0e0"]},
          "legend": {
            "title": null,
            "orient": "bottom-left",
            "offset": 0
          }
        }
      }
    },
    {
      "data": {
        "url": "data/world.csv"
      },
      "transform": [
        {
          "filter": "datum.Year == Year_Selection"
        },
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "https://cdn.jsdelivr.net/npm/vega-datasets@v1.29.0/data/world-110m.json",
              "format": {"type": "topojson", "feature": "countries"}
            },
            "key": "id"
          },
          "as": "geo"
        },
        {
          "calculate": "datum[Category_Selection]",
          "as": "Selected_Value"
        }
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "shape": {"field": "geo", "type": "geojson"},
        "color": {
          "field": "Selected_Value",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": {
              "expr": "Category_Selection == 'total_threatened' ? [500, 1000, 1500, 2000] : [100, 300, 500, 700]"
            },
            "range": ["#ffffcc", "#c2e699", "#78c679", "#31a354", "#006837"]
          },
          "legend": {
            "title": {
              "expr": "Category_Selection == 'total_threatened' ? 'Total' : Category_Selection == 'plants' ? 'Plants' : Category_Selection == 'vertebrates' ? 'Vertebrates' : 'Invertebrates'"
            },
            "orient": "bottom-left",
            "format": "d"
          }
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "Year", "type": "ordinal", "title": "Year"},
          {"field": "total_threatened", "type": "quantitative", "title": "Total"},
          {"field": "vertebrates", "type": "quantitative", "title": "Vertebrates"},
          {"field": "invertebrates", "type": "quantitative", "title": "Invertebrates"},
          {"field": "plants", "type": "quantitative", "title": "Plants"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null, "fill": "lightblue"}
  }
}